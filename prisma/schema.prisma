generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Question {
  id        Int      @id @default(autoincrement())
  label     String
  hint      String?
  type      String
  options   String?
  order     Int      @default(0)
  required  Boolean  @default(false)
  isActive  Boolean  @default(true)
  category  String   @default("diet")
  createdAt DateTime @default(now())
}

model Consultation {
  id               Int      @id @default(autoincrement())
  category         String   @default("diet")
  name             String
  phone            String?
  ssn              String?
  gender           String?
  heightWeight     String?
  lowestWeight     String?
  dietExperience   String?
  weightGainType   String?
  lifestyle        String?
  thermalSense     String?
  digestion        String?
  appetiteChest    String?
  sleepEnergy      String?
  sleepDuration    String?
  physicalSymptoms String?
  femaleHealth     String?
  contactTime      String?
  programInterest  String?
  answersJson      String?
  isRead           Boolean  @default(false)
  privacyAgreed    Boolean  @default(false)
  createdAt        DateTime @default(now())
}
